@model CompanyProfileMVC.Areas.Admin.Models.CategoryListViewModel
@{
  ViewData["Title"] = "Category - Analytics";
}
@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.css" />
}
@section VendorScripts {
<script src="~/vendor/libs/apex-charts/apexcharts.js"></script>
}
@section PageScripts {
<script src="~/js/dashboards-analytics.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    var addForm = document.getElementById('addCategoryForm');
    var addInput = document.getElementById('nameBasic');
    var addError = document.getElementById('nameBasicError');
    var addSpinner = document.getElementById('addCategorySpinner');
    var addSubmitBtn = addForm.querySelector('button[type="submit"]');
    var addModalEl = document.getElementById('basicModal');
    var addModal = bootstrap.Modal.getOrCreateInstance(addModalEl);

    var editForm = document.getElementById('editCategoryForm');
    var editIdInput = document.getElementById('editCategoryId');
    var editNameInput = document.getElementById('editCategoryName');
    var editError = document.getElementById('editCategoryNameError');
    var editSpinner = document.getElementById('editCategorySpinner');
    var editSubmitBtn = editForm.querySelector('button[type="submit"]');
    var editModalEl = document.getElementById('editCategoryModal');
    var editModal = bootstrap.Modal.getOrCreateInstance(editModalEl);

    var deleteForm = document.getElementById('deleteCategoryForm');
    var deleteIdInput = document.getElementById('deleteCategoryId');

    var tableBody = document.getElementById('categoryTableBody');
    var paginationEl = document.getElementById('categoryPagination');
    var listUrl = '@Url.Action("List", "Category")';
    var currentPage = @Model.Page;

    function buildActionCell(id, name) {
      var actionCell = document.createElement('td');

      var editBtn = document.createElement('button');
      editBtn.type = 'button';
      editBtn.className = 'btn btn-primary btn-sm me-2';
      editBtn.dataset.action = 'edit';
      editBtn.dataset.id = id;
      editBtn.dataset.name = name;
      editBtn.textContent = 'Edit';

      var deleteBtn = document.createElement('button');
      deleteBtn.type = 'button';
      deleteBtn.className = 'btn btn-danger btn-sm';
      deleteBtn.dataset.action = 'delete';
      deleteBtn.dataset.id = id;
      deleteBtn.textContent = 'Delete';

      actionCell.appendChild(editBtn);
      actionCell.appendChild(deleteBtn);
      return actionCell;
    }

    function renderRows(items) {
      tableBody.innerHTML = '';

      if (items.length === 0) {
        var emptyRow = document.createElement('tr');
        var emptyCell = document.createElement('td');
        emptyCell.colSpan = 3;
        emptyCell.className = 'text-center';
        emptyCell.textContent = 'Belum ada data';
        emptyRow.appendChild(emptyCell);
        tableBody.appendChild(emptyRow);
        return;
      }

      items.forEach(function (category) {
        var row = document.createElement('tr');

        var idCell = document.createElement('td');
        idCell.textContent = category.id;

        var nameCell = document.createElement('td');
        nameCell.textContent = category.name;

        row.appendChild(idCell);
        row.appendChild(nameCell);
        row.appendChild(buildActionCell(category.id, category.name));
        tableBody.appendChild(row);
      });
    }

    function renderPagination(page, totalPages) {
      paginationEl.innerHTML = '';

      function addItem(label, targetPage, disabled, active) {
        var li = document.createElement('li');
        li.className = 'page-item' + (disabled ? ' disabled' : '') + (active ? ' active' : '');

        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'page-link';
        btn.textContent = label;
        btn.disabled = disabled;
        if (!disabled) {
          btn.dataset.page = targetPage;
        }

        li.appendChild(btn);
        paginationEl.appendChild(li);
      }

      addItem('Previous', page - 1, page <= 1, false);
      for (var p = 1; p <= totalPages; p++) {
        addItem(String(p), p, false, p === page);
      }
      addItem('Next', page + 1, page >= totalPages, false);
    }

    async function loadPage(page) {
      var response = await fetch(listUrl + '?page=' + page);
      if (!response.ok) return null;

      var result = await response.json();
      currentPage = result.page;
      renderRows(result.items);
      renderPagination(result.page, result.totalPages);
      return result;
    }

    async function reloadAfterMutation() {
      var result = await loadPage(currentPage);
      if (result && result.items.length === 0 && result.page > 1) {
        await loadPage(result.page - 1);
      }
    }

    paginationEl.addEventListener('click', function (e) {
      var btn = e.target.closest('button[data-page]');
      if (!btn || btn.disabled) return;
      loadPage(parseInt(btn.dataset.page, 10));
    });

    // Add Category
    function setAddLoading(isLoading) {
      addSubmitBtn.disabled = isLoading;
      addSpinner.classList.toggle('d-none', !isLoading);
    }

    function setAddError(message) {
      addError.textContent = message || '';
      addInput.classList.toggle('is-invalid', !!message);
    }

    addModalEl.addEventListener('hidden.bs.modal', function () {
      addForm.reset();
      setAddError('');
    });

    addForm.addEventListener('submit', async function (e) {
      e.preventDefault();
      setAddError('');
      setAddLoading(true);

      try {
        var response = await fetch(addForm.action, {
          method: 'POST',
          body: new FormData(addForm)
        });

        if (!response.ok) {
          var problem = await response.json().catch(function () { return {}; });
          setAddError(problem.message || 'Gagal menyimpan kategori');
          return;
        }

        addModal.hide();
        await reloadAfterMutation();
      } catch (err) {
        setAddError('Terjadi kesalahan koneksi, coba lagi');
      } finally {
        setAddLoading(false);
      }
    });

    // Edit Category
    function setEditLoading(isLoading) {
      editSubmitBtn.disabled = isLoading;
      editSpinner.classList.toggle('d-none', !isLoading);
    }

    function setEditError(message) {
      editError.textContent = message || '';
      editNameInput.classList.toggle('is-invalid', !!message);
    }

    editModalEl.addEventListener('hidden.bs.modal', function () {
      editForm.reset();
      setEditError('');
    });

    editForm.addEventListener('submit', async function (e) {
      e.preventDefault();
      setEditError('');
      setEditLoading(true);

      try {
        var response = await fetch(editForm.action, {
          method: 'POST',
          body: new FormData(editForm)
        });

        if (!response.ok) {
          var problem = await response.json().catch(function () { return {}; });
          setEditError(problem.message || 'Gagal menyimpan perubahan');
          return;
        }

        editModal.hide();
        await loadPage(currentPage);
      } catch (err) {
        setEditError('Terjadi kesalahan koneksi, coba lagi');
      } finally {
        setEditLoading(false);
      }
    });

    // Edit / Delete triggers (event delegation, rows are re-rendered dynamically)
    tableBody.addEventListener('click', async function (e) {
      var editBtn = e.target.closest('button[data-action="edit"]');
      if (editBtn) {
        editIdInput.value = editBtn.dataset.id;
        editNameInput.value = editBtn.dataset.name;
        setEditError('');
        editModal.show();
        return;
      }

      var deleteBtn = e.target.closest('button[data-action="delete"]');
      if (deleteBtn) {
        if (!confirm('Hapus kategori ini?')) return;

        deleteBtn.disabled = true;
        try {
          deleteIdInput.value = deleteBtn.dataset.id;
          var response = await fetch(deleteForm.action, {
            method: 'POST',
            body: new FormData(deleteForm)
          });

          if (!response.ok) {
            alert('Gagal menghapus kategori');
            return;
          }

          await reloadAfterMutation();
        } finally {
          deleteBtn.disabled = false;
        }
      }
    });
  });
</script>
}

@* ************** Content ************** *@

<div class="row gy-6">
  <!-- Bootstrap modals -->
  <div class="col-lg-12">
    <div class="card">
      <h5 class="card-header">Category List Data</h5>
      <div class="card-body">
        <div class="row gy-3">
          <!-- Default Modal -->
          <div class="col-lg-4 col-md-6 mb-4">
            <div class="mt-2">
              <!-- Button trigger modal -->
              <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#basicModal">Add Category</button>

              <!-- Add Category Modal -->
              <div class="modal fade" id="basicModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog" role="document">
                  <form id="addCategoryForm" asp-controller="Category" asp-action="Create" method="post">
                    <div class="modal-content">
                      <div class="modal-header">
                        <h5 class="modal-title" id="exampleModalLabel1">Add Category</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                      </div>
                      <div class="modal-body">
                        <div class="row g-6">
                          <div class="col mb-6">
                            <label for="nameBasic" class="form-label">Name</label>
                            <input type="text" name="Name" id="nameBasic" class="form-control" placeholder="Enter Name" />
                            <div class="invalid-feedback d-block" id="nameBasicError"></div>
                          </div>
                        </div>
                      </div>
                      <div class="modal-footer">
                        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary">
                          <span class="spinner-border spinner-border-sm d-none" id="addCategorySpinner"></span>
                          Save changes
                        </button>
                      </div>
                    </div>
                  </form>
                </div>
              </div>

              <!-- Edit Category Modal -->
              <div class="modal fade" id="editCategoryModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog" role="document">
                  <form id="editCategoryForm" asp-controller="Category" asp-action="Update" method="post">
                    <input type="hidden" name="Id" id="editCategoryId" />
                    <div class="modal-content">
                      <div class="modal-header">
                        <h5 class="modal-title">Edit Category</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                      </div>
                      <div class="modal-body">
                        <div class="row g-6">
                          <div class="col mb-6">
                            <label for="editCategoryName" class="form-label">Name</label>
                            <input type="text" name="Name" id="editCategoryName" class="form-control" placeholder="Enter Name" />
                            <div class="invalid-feedback d-block" id="editCategoryNameError"></div>
                          </div>
                        </div>
                      </div>
                      <div class="modal-footer">
                        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary">
                          <span class="spinner-border spinner-border-sm d-none" id="editCategorySpinner"></span>
                          Save changes
                        </button>
                      </div>
                    </div>
                  </form>
                </div>
              </div>

              <!-- Delete Category Form (hidden, submitted via JS) -->
              <form id="deleteCategoryForm" asp-controller="Category" asp-action="Delete" method="post" class="d-none">
                <input type="hidden" name="id" id="deleteCategoryId" />
              </form>
            </div>
          </div>
        </div>

        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Nama Lengkap</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody id="categoryTableBody">
              @if (Model.Items.Count == 0)
              {
                <tr>
                  <td colspan="3" class="text-center">Belum ada data</td>
                </tr>
              }
              else
              {
                @foreach (var category in Model.Items)
                {
                  <tr>
                    <td>@category.Id</td>
                    <td>@category.Name</td>
                    <td>
                      <button type="button" class="btn btn-primary btn-sm me-2" data-action="edit" data-id="@category.Id" data-name="@category.Name">Edit</button>
                      <button type="button" class="btn btn-danger btn-sm" data-action="delete" data-id="@category.Id">Delete</button>
                    </td>
                  </tr>
                }
              }
            </tbody>
          </table>
        </div>

        <nav>
          <ul class="pagination justify-content-end" id="categoryPagination">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
              @if (Model.Page <= 1)
              {
                <button type="button" class="page-link" disabled>Previous</button>
              }
              else
              {
                <button type="button" class="page-link" data-page="@(Model.Page - 1)">Previous</button>
              }
            </li>
            @for (int p = 1; p <= Model.TotalPages; p++)
            {
              <li class="page-item @(p == Model.Page ? "active" : "")">
                <button type="button" class="page-link" data-page="@p">@p</button>
              </li>
            }
            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
              @if (Model.Page >= Model.TotalPages)
              {
                <button type="button" class="page-link" disabled>Next</button>
              }
              else
              {
                <button type="button" class="page-link" data-page="@(Model.Page + 1)">Next</button>
              }
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </div>
</div>

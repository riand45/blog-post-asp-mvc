@model List<CompanyProfileMVC.Areas.Admin.Models.CategoryViewModel>
@{
  ViewData["Title"] = "Category - Analytics";
}
@section VendorStyles {
<link rel="stylesheet" href="~/vendor/libs/apex-charts/apex-charts.css" />
}
@section VendorScripts {
<script src="~/vendor/libs/apex-charts/apexcharts.js"></script>
}
@section PageScripts {
<script src="~/js/dashboards-analytics.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    var form = document.getElementById('addCategoryForm');
    var input = document.getElementById('nameBasic');
    var errorEl = document.getElementById('nameBasicError');
    var spinner = document.getElementById('addCategorySpinner');
    var submitBtn = form.querySelector('button[type="submit"]');
    var modalEl = document.getElementById('basicModal');
    var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
    var tableBody = document.getElementById('categoryTableBody');

    function setLoading(isLoading) {
      submitBtn.disabled = isLoading;
      spinner.classList.toggle('d-none', !isLoading);
    }

    function setError(message) {
      errorEl.textContent = message || '';
      input.classList.toggle('is-invalid', !!message);
    }

    modalEl.addEventListener('hidden.bs.modal', function () {
      form.reset();
      setError('');
    });

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      setError('');
      setLoading(true);

      try {
        var response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form)
        });

        if (!response.ok) {
          var problem = await response.json().catch(function () { return {}; });
          setError(problem.message || 'Gagal menyimpan kategori');
          return;
        }

        var category = await response.json();

        var row = document.createElement('tr');
        row.innerHTML =
          '<td>' + category.id + '</td>' +
          '<td></td>' +
          '<td><button type="button" class="btn btn-primary btn-sm" data-id="' + category.id + '">Edit</button></td>';
        row.querySelector('td:nth-child(2)').textContent = category.name;
        tableBody.appendChild(row);

        modal.hide();
      } catch (err) {
        setError('Terjadi kesalahan koneksi, coba lagi');
      } finally {
        setLoading(false);
      }
    });
  });
</script>
}

@* ************** Content ************** *@

<div class="row gy-6">
  <!-- Bootstrap modals -->
  <div class="col-lg-12">
    <div class="card">
      <h5 class="card-header">Category List Data</h5>
      <div class="card-body">
        <div class="row gy-3">
          <!-- Default Modal -->
          <div class="col-lg-4 col-md-6 mb-4">
            <div class="mt-2">
              <!-- Button trigger modal -->
              <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#basicModal">Add Category</button>

              <!-- Modal -->
              <div class="modal fade" id="basicModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog" role="document">
                  <form id="addCategoryForm" asp-controller="Category" asp-action="Create" method="post">
                    <div class="modal-content">
                      <div class="modal-header">
                        <h5 class="modal-title" id="exampleModalLabel1">Add Category</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                      </div>
                      <div class="modal-body">
                        <div class="row g-6">
                          <div class="col mb-6">
                            <label for="nameBasic" class="form-label">Name</label>
                            <input type="text" name="Name" id="nameBasic" class="form-control" placeholder="Enter Name" />
                            <div class="invalid-feedback d-block" id="nameBasicError"></div>
                          </div>
                        </div>
                      </div>
                      <div class="modal-footer">
                        <button type="button" class="btn btn-label-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="submit" class="btn btn-primary">
                          <span class="spinner-border spinner-border-sm d-none" id="addCategorySpinner"></span>
                          Save changes
                        </button>
                      </div>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr>
                <th>ID</th>
                <th>Nama Lengkap</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody id="categoryTableBody">
              @foreach (var category in Model)
              {
                <tr>
                  <td>@category.Id</td>
                  <td>@category.Name</td>
                  <td>
                    <button type="button" class="btn btn-primary btn-sm" data-id="@category.Id">Edit</button>
                  </td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>